<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.SenBibliotheque.entity.controller.modules.AddBookDialogController"
            style="-fx-background-color: #f0f9ff; -fx-padding: 0;">

    <VBox spacing="20" style="-fx-padding: 40; -fx-background-color: #f0f9ff;">

        <!-- Titre -->
        <Label text="📚 Ajouter / Modifier un livre"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0e7490;"/>

        <!-- ================== SECTION 1 ================== -->
        <VBox spacing="12"
              style="-fx-padding: 15;
                     -fx-background-color: white;
                     -fx-border-radius: 4;
                     -fx-background-radius: 4;
                     -fx-border-color: #a7f3d0;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">

            <Label text="📖 Informations de Base"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #0e7490;"/>

            <GridPane hgap="15" vgap="15">

                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <!-- ISBN -->
                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="ISBN"
                           style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-font-size: 11;"/>
                    <TextField fx:id="isbnField" promptText="Ex: 978..."
                               style="-fx-padding: 8;
                                      -fx-border-radius: 4;
                                      -fx-background-radius: 4;
                                      -fx-border-color: #a7f3d0;
                                      -fx-border-width: 1;"/>
                </VBox>

                <!-- Titre -->
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Titre"
                           style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-font-size: 11;"/>
                    <TextField fx:id="titreField"
                               style="-fx-padding: 8;
                                      -fx-border-radius: 4;
                                      -fx-background-radius: 4;
                                      -fx-border-color: #a7f3d0;
                                      -fx-border-width: 1;"/>
                </VBox>

                <!-- Auteur -->
                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Auteur"
                           style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-font-size: 11;"/>
                    <TextField fx:id="auteurField"
                               style="-fx-padding: 8;
                                      -fx-border-radius: 4;
                                      -fx-background-radius: 4;
                                      -fx-border-color: #a7f3d0;
                                      -fx-border-width: 1;"/>
                </VBox>

                <!-- Année -->
                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Année"
                           style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-font-size: 11;"/>
                    <TextField fx:id="anneeField"
                               style="-fx-padding: 8;
                                      -fx-border-radius: 4;
                                      -fx-background-radius: 4;
                                      -fx-border-color: #a7f3d0;
                                      -fx-border-width: 1;"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- ================== SECTION 2 ================== -->
        <VBox spacing="12"
              style="-fx-padding: 15;
                     -fx-background-color: white;
                     -fx-border-radius: 4;
                     -fx-background-radius: 4;
                     -fx-border-color: #a7f3d0;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">

            <Label text="🏷️ Catégorie et Disponibilité"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #0e7490;"/>

            <GridPane hgap="15" vgap="15">

                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Catégorie"
                           style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-font-size: 11;"/>
                    <ComboBox fx:id="categorieComboBox"
                              style="-fx-padding: 8;
                                     -fx-border-radius: 4;
                                     -fx-background-radius: 4;
                                     -fx-border-color: #a7f3d0;
                                     -fx-border-width: 1;"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Exemplaires"
                           style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-font-size: 11;"/>
                    <Spinner fx:id="exemplairesSpinner"
                             style="-fx-border-color: #a7f3d0; -fx-border-width: 1;"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Disponibles"
                           style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-font-size: 11;"/>
                    <Spinner fx:id="disponibleSpinner"
                             style="-fx-border-color: #a7f3d0; -fx-border-width: 1;"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- ================== DESCRIPTION ================== -->
        <VBox spacing="12"
              style="-fx-padding: 15;
                     -fx-background-color: white;
                     -fx-border-radius: 4;
                     -fx-background-radius: 4;
                     -fx-border-color: #a7f3d0;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">

            <Label text="📝 Description"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #0e7490;"/>

            <TextArea fx:id="descriptionArea" prefRowCount="4"
                      style="-fx-padding: 8;
                             -fx-border-radius: 4;
                             -fx-background-radius: 4;
                             -fx-border-color: #a7f3d0;
                             -fx-border-width: 1;"/>
        </VBox>

        <!-- Erreur -->
        <Label fx:id="errorLabel"
               style="-fx-text-fill: #ef4444; -fx-font-size: 11;"/>

    </VBox>
</ScrollPane>