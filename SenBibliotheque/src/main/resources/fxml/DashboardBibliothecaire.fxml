<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f0f9ff;"
            stylesheets="@../css/dashboard.css,@../css/sidebar.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.SenBibliotheque.entity.controller.DashboardBibliothecaireController">

    <!-- TOP BAR PROFESSIONNELLE -->
    <top>
        <VBox>
            <HBox fx:id="titleBar"
                  styleClass="title-bar">

                <Label style="-fx-font-size: 16;
                             -fx-font-weight: bold;"
                       text="📚 BookHome"
                       styleClass="title-bar-label"/>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="minimizeBtn"
                        onAction="#minimizeWindow"
                        text="−"
                        styleClass="window-button"/>

                <Button fx:id="maximizeBtn"
                        onAction="#maximizeWindow"
                        text="⬜"
                        styleClass="window-button"/>

                <Button fx:id="closeBtn"
                        onAction="#closeWindow"
                        text="✕"
                        styleClass="window-button close-button"/>
            </HBox>

            <!-- Contenu principal du top bar -->
            <HBox style="-fx-padding: 15;
                         -fx-background-color: #f0f9ff;
                         -fx-border-color: #a7f3d0;
                         -fx-border-width: 0 0 1 0;
                         -fx-alignment: CENTER_LEFT;
                         -fx-spacing: 15;">

                <Label fx:id="pageTitle"
                       style="-fx-font-size: 24;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0e7490;"
                       text="Dashboard" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="clockLabel"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 12;" />
            </HBox>
        </VBox>
    </top>

    <!-- SIDEBAR RESTREINT -->
    <left>
        <VBox fx:id="sidebarPane"
              styleClass="sidebar-vbox">

            <!-- Header -->
            <HBox styleClass="sidebar-header">
                <Label text="📋 Menu"
                       styleClass="sidebar-header-label"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="collapseBtn"
                        onAction="#toggleSidebar"
                        text="▶"
                        styleClass="collapse-button" />
            </HBox>

            <!-- User Info -->
            <VBox styleClass="user-info">
                <Label fx:id="userNameLabel"
                       text="Bibliothécaire"
                       styleClass="user-name"/>
                <Label fx:id="userRoleLabel"
                       text="Accès restreint"
                       styleClass="user-role"/>
            </VBox>

            <!-- Menu - RESTREINT POUR BIBLIOTHECAIRE -->
            <ScrollPane fitToWidth="true"
                        styleClass="sidebar-scroll"
                        VBox.vgrow="ALWAYS">

                <VBox styleClass="sidebar-menu">

                    <!-- Dashboard -->
                    <Button fx:id="dashboardBtn"
                            maxWidth="Infinity"
                            onAction="#loadDashboard"
                            styleClass="sidebar-button sidebar-button-active"
                            text="📊 Dashboard" />

                    <!-- Livres (Consultation seulement) -->
                    <Button fx:id="booksBtn"
                            maxWidth="Infinity"
                            onAction="#loadBooks"
                            styleClass="sidebar-button"
                            text="📖 Livres (Consultation)" />

                    <!-- Adhérents -->
                    <Button fx:id="membersBtn"
                            maxWidth="Infinity"
                            onAction="#loadMembers"
                            styleClass="sidebar-button"
                            text="🎫 Adhérents" />

                    <!-- Emprunts -->
                    <Button fx:id="borrowsBtn"
                            maxWidth="Infinity"
                            onAction="#loadBorrows"
                            styleClass="sidebar-button"
                            text="🔄 Emprunts" />

                    <Region VBox.vgrow="ALWAYS" />

                    <!-- Déconnexion -->
                    <Button fx:id="logoutBtn"
                            maxWidth="Infinity"
                            onAction="#logout"
                            styleClass="logout-button"
                            text="🚪 Déconnexion" />
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <StackPane fx:id="contentPane"
                   styleClass="content-pane">
        </StackPane>
    </center>
</BorderPane>