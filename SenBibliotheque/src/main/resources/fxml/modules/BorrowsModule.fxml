<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.SenBibliotheque.entity.controller.modules.BorrowsModuleController"
      spacing="15" style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <!-- Onglets -->
    <TabPane style="-fx-padding: 0;">
        <!-- Onglet: Nouveaux Emprunts -->
        <Tab text="📌 Nouvel Emprunt" closable="false">
            <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5;">
                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Adhérent" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="memberCombo" style="-fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5;" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Livre" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="bookCombo" style="-fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5;" maxWidth="Infinity"/>
                    </VBox>
                </HBox>
                <HBox spacing="10">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Date de retour prévue" style="-fx-font-weight: bold;"/>
                        <DatePicker fx:id="returnDatePicker" style="-fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5;" maxWidth="Infinity"/>
                    </VBox>
                </HBox>
                <HBox spacing="10" style="-fx-alignment: CENTER_RIGHT; -fx-padding: 15 0 0 0;">
                    <Button text="Enregistrer" style="-fx-padding: 10 20; -fx-background-color: #28a745; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold;"
                            onAction="#enregistrerEmprunt"/>
                    <Button text="Annuler" style="-fx-padding: 10 20; -fx-background-color: #f8f9fa; -fx-border-color: #d0d0d0; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;"
                            onAction="#annulerEmprunt"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- Onglet: Emprunts en cours -->
        <Tab text="🔄 Emprunts en cours" closable="false">
            <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5;">
                <HBox spacing="10" style="-fx-alignment: CENTER_LEFT;">
                    <TextField fx:id="searchActiveField" promptText="Rechercher..." style="-fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5; -fx-min-width: 250;"/>
                    <Button text="🔍 Rechercher" style="-fx-padding: 10 20; -fx-background-color: #f8f9fa; -fx-border-color: #d0d0d0; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;"
                            onAction="#rechercherActifs"/>
                </HBox>
                <TableView fx:id="activeBorrowsTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 11; -fx-padding: 0;">
                    <columns>
                        <TableColumn text="Adhérent" prefWidth="120" resizable="false"/>
                        <TableColumn text="Livre" prefWidth="150" resizable="false"/>
                        <TableColumn text="Emprunt" prefWidth="100" resizable="false"/>
                        <TableColumn text="Retour prévu" prefWidth="100" resizable="false"/>
                        <TableColumn text="Actions" prefWidth="150" resizable="false"/>
                    </columns>
                </TableView>
                <Label fx:id="activeBorrowsStatus" text="0 emprunt(s)" style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
            </VBox>
        </Tab>

        <!-- Onglet: Retards -->
        <Tab text="⏰ Emprunts en retard" closable="false">
            <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5;">
                <HBox spacing="10" style="-fx-alignment: CENTER_LEFT;">
                    <TextField fx:id="searchOverdueField" promptText="Rechercher..." style="-fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5; -fx-min-width: 250;"/>
                    <Button text="🔍 Rechercher" style="-fx-padding: 10 20; -fx-background-color: #f8f9fa; -fx-border-color: #d0d0d0; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;"
                            onAction="#rechercherRetards"/>
                </HBox>
                <TableView fx:id="overdueTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 11; -fx-padding: 0;">
                    <columns>
                        <TableColumn text="Adhérent" prefWidth="120" resizable="false"/>
                        <TableColumn text="Livre" prefWidth="150" resizable="false"/>
                        <TableColumn text="Retour prévu" prefWidth="100" resizable="false"/>
                        <TableColumn text="Retard (j)" prefWidth="80" resizable="false"/>
                        <TableColumn text="Pénalité (FCFA)" prefWidth="120" resizable="false"/>
                        <TableColumn text="Actions" prefWidth="150" resizable="false"/>
                    </columns>
                </TableView>
                <Label fx:id="overdueStatus" text="0 retard(s)" style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>