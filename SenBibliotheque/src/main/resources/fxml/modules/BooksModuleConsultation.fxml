<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.SenBibliotheque.entity.controller.modules.BooksModuleConsultationController"
      spacing="15"
      style="-fx-padding: 20; -fx-background-color: #f0f9ff;">

    <!-- Titre de la page -->
    <Label text="📖 Consultation des Livres"
           style="-fx-font-size: 24;
                  -fx-font-weight: bold;
                  -fx-text-fill: #0e7490;"/>

    <!-- Alerte Lecture Seule -->
    <HBox spacing="10"
          style="-fx-alignment: CENTER_LEFT;
                 -fx-padding: 12;
                 -fx-background-color: #fef3c7;
                 -fx-border-radius: 8;
                 -fx-background-radius: 8;
                 -fx-border-color: #f59e0b;
                 -fx-border-width: 2;
                 -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.15), 4, 0, 0, 1);">

        <Label text="ℹ️ CONSULTATION SEULE (Lecture)"
               style="-fx-font-size: 12;
                      -fx-font-weight: bold;
                      -fx-text-fill: #b45309;"/>

        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Barre d'outils (Recherche à gauche, Filtres à droite) -->
    <HBox spacing="15"
          style="-fx-alignment: CENTER_LEFT;
                 -fx-padding: 15;
                 -fx-background-color: white;
                 -fx-border-radius: 10;
                 -fx-background-radius: 10;
                 -fx-border-color: #e5e7eb;
                 -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

        <!-- Groupe de recherche (Gauche) -->
        <HBox spacing="10" style="-fx-alignment: CENTER_LEFT;">
            <TextField fx:id="searchField"
                       promptText="🔍 Titre, auteur ou ISBN..."
                       style="-fx-padding: 10;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-min-width: 300;
                              -fx-border-color: #a7f3d0;
                              -fx-border-width: 1;
                              -fx-font-size: 11;"/>

            <Button text="🔍 Rechercher"
                    style="-fx-padding: 10 20;
                           -fx-background-color: #06b6d4;
                           -fx-text-fill: white;
                           -fx-border-radius: 6;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;
                           -fx-font-weight: bold;
                           -fx-font-size: 11;
                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 1);"
                    onAction="#rechercher"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Filtres (Droite) -->
        <ComboBox fx:id="filterCategory"
                  promptText="🏷️ Catégorie"
                  style="-fx-padding: 10;
                         -fx-border-radius: 6;
                         -fx-background-radius: 6;
                         -fx-min-width: 160;
                         -fx-border-color: #a7f3d0;
                         -fx-border-width: 1;
                         -fx-font-size: 11;"/>
    </HBox>

    <!-- Tableau des livres -->
    <VBox style="-fx-padding: 15;
                 -fx-background-color: white;
                 -fx-border-radius: 10;
                 -fx-background-radius: 10;
                 -fx-border-color: #e5e7eb;
                 -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
          VBox.vgrow="ALWAYS">

        <Label text="📚 Liste des livres"
               style="-fx-font-size: 13;
                      -fx-font-weight: bold;
                      -fx-text-fill: #1f2937;
                      -fx-padding: 0 0 10 0;"/>

        <TableView fx:id="booksTable"
                   VBox.vgrow="ALWAYS"
                   style="-fx-font-size: 11;
                          -fx-padding: 0;
                          -fx-border-color: #e5e7eb;"/>
    </VBox>

    <!-- Pied de page (Statut) -->
    <HBox style="-fx-alignment: CENTER_LEFT;
                 -fx-padding: 10;
                 -fx-background-color: white;
                 -fx-border-radius: 10;
                 -fx-background-radius: 10;
                 -fx-border-color: #e5e7eb;
                 -fx-border-width: 1;">

        <Label fx:id="statusLabel"
               text="0 livre(s)"
               style="-fx-font-size: 11;
                      -fx-text-fill: #6b7280;
                      -fx-font-weight: 500;"/>
    </HBox>

</VBox>