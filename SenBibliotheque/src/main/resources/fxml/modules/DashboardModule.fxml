<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.SenBibliotheque.entity.controller.modules.DashboardModuleController"
            style="-fx-background-color: #f5f5f5; -fx-padding: 0;">

    <VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

        <!-- Titre Principal -->
        <Label text="📊 Tableau de Bord Administrateur"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>

        <!-- ========================================== -->
        <!-- SECTION 1 : CARTES KPI (STATISTIQUES) -->
        <!-- ========================================== -->

        <HBox spacing="15" style="-fx-alignment: CENTER_LEFT;">

            <!-- Carte 1 : Total Livres -->
            <VBox spacing="8"
                  style="-fx-padding: 18;
                         -fx-background-color: white;
                         -fx-border-color: #e5e7eb;
                         -fx-border-width: 1;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-pref-width: 200;
                         -fx-pref-height: 140;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

                <Label text="📚"
                       style="-fx-font-size: 32; -fx-text-alignment: CENTER;"/>

                <Label fx:id="totalBooksLabel"
                       text="0"
                       style="-fx-font-size: 28;
                              -fx-font-weight: bold;
                              -fx-text-fill: #3b82f6;
                              -fx-text-alignment: CENTER;"/>

                <Label text="Livres en stock"
                       style="-fx-font-size: 12; -fx-text-fill: #6b7280; -fx-text-alignment: CENTER;"/>

                <Label fx:id="booksDetailsLabel"
                       text="0 disponibles"
                       style="-fx-font-size: 11; -fx-text-fill: #9ca3af; -fx-text-alignment: CENTER;"/>
            </VBox>

            <!-- Carte 2 : Total Adhérents -->
            <VBox spacing="8"
                  style="-fx-padding: 18;
                         -fx-background-color: white;
                         -fx-border-color: #e5e7eb;
                         -fx-border-width: 1;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-pref-width: 200;
                         -fx-pref-height: 140;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

                <Label text="👥"
                       style="-fx-font-size: 32; -fx-text-alignment: CENTER;"/>

                <Label fx:id="totalMembersLabel"
                       text="0"
                       style="-fx-font-size: 28;
                              -fx-font-weight: bold;
                              -fx-text-fill: #10b981;
                              -fx-text-alignment: CENTER;"/>

                <Label text="Adhérents actifs"
                       style="-fx-font-size: 12; -fx-text-fill: #6b7280; -fx-text-alignment: CENTER;"/>

                <Label fx:id="membersDetailsLabel"
                       text="0 actifs"
                       style="-fx-font-size: 11; -fx-text-fill: #9ca3af; -fx-text-alignment: CENTER;"/>
            </VBox>

            <!-- Carte 3 : Emprunts en cours -->
            <VBox spacing="8"
                  style="-fx-padding: 18;
                         -fx-background-color: white;
                         -fx-border-color: #e5e7eb;
                         -fx-border-width: 1;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-pref-width: 200;
                         -fx-pref-height: 140;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

                <Label text="🔄"
                       style="-fx-font-size: 32; -fx-text-alignment: CENTER;"/>

                <Label fx:id="activeBorrowsLabel"
                       text="0"
                       style="-fx-font-size: 28;
                              -fx-font-weight: bold;
                              -fx-text-fill: #f59e0b;
                              -fx-text-alignment: CENTER;"/>

                <Label text="Emprunts en cours"
                       style="-fx-font-size: 12; -fx-text-fill: #6b7280; -fx-text-alignment: CENTER;"/>

                <Label fx:id="borrowsDetailsLabel"
                       text="ce mois"
                       style="-fx-font-size: 11; -fx-text-fill: #9ca3af; -fx-text-alignment: CENTER;"/>
            </VBox>

            <!-- Carte 4 : Retards -->
            <VBox spacing="8"
                  style="-fx-padding: 18;
                         -fx-background-color: white;
                         -fx-border-color: #fecaca;
                         -fx-border-width: 2;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-pref-width: 200;
                         -fx-pref-height: 140;
                         -fx-effect: dropshadow(gaussian, rgba(220,38,38,0.15), 8, 0, 0, 2);">

                <Label text="⏰"
                       style="-fx-font-size: 32; -fx-text-alignment: CENTER;"/>

                <Label fx:id="overdueLabel"
                       text="0"
                       style="-fx-font-size: 28;
                              -fx-font-weight: bold;
                              -fx-text-fill: #dc2626;
                              -fx-text-alignment: CENTER;"/>

                <Label text="Retards signalés"
                       style="-fx-font-size: 12; -fx-text-fill: #6b7280; -fx-text-alignment: CENTER;"/>

                <Label fx:id="overdueDetailsLabel"
                       text="À traiter"
                       style="-fx-font-size: 11; -fx-text-fill: #9ca3af; -fx-text-alignment: CENTER;"/>
            </VBox>
        </HBox>

        <!-- ========================================== -->
        <!-- SECTION 2 : TABLEAU DES RETARDS -->
        <!-- ========================================== -->

        <VBox spacing="10"
              style="-fx-padding: 15;
                     -fx-background-color: white;
                     -fx-border-radius: 10;
                     -fx-border-color: #fecaca;
                     -fx-border-width: 2;
                     -fx-effect: dropshadow(gaussian, rgba(220,38,38,0.15), 8, 0, 0, 2);
                     VBox.vgrow: ALWAYS;">

            <Label text="🚨 Emprunts en Retard"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>

            <TableView fx:id="overdueTable"
                       style="-fx-font-size: 11;"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Adhérent" prefWidth="150" resizable="true"/>
                    <TableColumn text="Livre" prefWidth="200" resizable="true"/>
                    <TableColumn text="Retour prévu" prefWidth="130" resizable="true"/>
                    <TableColumn text="Retard (j)" prefWidth="100" resizable="true"/>
                    <TableColumn text="Pénalité (FCFA)" prefWidth="150" resizable="true"/>
                </columns>
            </TableView>

            <Label fx:id="overdueTableStatus"
                   text="0 retard(s)"
                   style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-padding: 10 0 0 0;"/>
        </VBox>

    </VBox>
</ScrollPane>