<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f0f9ff;" stylesheets="@../css/dashboard.css,@../css/sidebar.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.SenBibliotheque.entity.controller.DashboardController">

    <!-- TOP BAR PROFESSIONNELLE -->
    <top>
        <VBox>
            <HBox fx:id="titleBar" styleClass="title-bar">

                <Label fx:id="pageTitle" style="-fx-font-size: 24;                               -fx-font-weight: bold;" styleClass="title-bar-label" text="Dashboard" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="clockLabel" styleClass="title-bar-label" />
            </HBox>
        </VBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox fx:id="sidebarPane" styleClass="sidebar-vbox">

            <!-- Header -->
            <HBox styleClass="sidebar-header">

                <Label styleClass="sidebar-header-label" text="📋 Menu" />

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="collapseBtn" onAction="#toggleSidebar" styleClass="collapse-button" text="▶" />
            </HBox>

            <!-- User Info -->
            <VBox styleClass="user-info">

                <Label fx:id="userNameLabel" styleClass="user-name" text="Admin" />

                <Label fx:id="userRoleLabel" styleClass="user-role" text="Administrateur" />
            </VBox>

            <!-- Menu -->
            <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">

                <VBox styleClass="sidebar-menu">

                    <Button fx:id="dashboardBtn" maxWidth="Infinity" onAction="#loadDashboard" styleClass="sidebar-button sidebar-button-active" text="📊 Dashboard" />

                    <Button fx:id="usersBtn" maxWidth="Infinity" onAction="#loadUsers" styleClass="sidebar-button" text="👥 Utilisateurs" />

                    <Button fx:id="booksBtn" maxWidth="Infinity" onAction="#loadBooks" styleClass="sidebar-button" text="📖 Livres" />

                    <Button fx:id="categoriesBtn" maxWidth="Infinity" onAction="#loadCategories" styleClass="sidebar-button" text="🏷️ Catégories" />

                    <Button fx:id="membersBtn" maxWidth="Infinity" onAction="#loadMembers" styleClass="sidebar-button" text="🎫 Adhérents" />

                    <Button fx:id="borrowsBtn" maxWidth="Infinity" onAction="#loadBorrows" styleClass="sidebar-button" text="🔄 Emprunts" />

                    <Button fx:id="reportsBtn" maxWidth="Infinity" onAction="#loadReports" styleClass="sidebar-button" text="📈 Rapports" />

                    <Region VBox.vgrow="ALWAYS" />

                    <Button fx:id="logoutBtn" maxWidth="Infinity" onAction="#logout" styleClass="logout-button" text="🚪 Déconnexion" />
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane">
        </StackPane>
    </center>
</BorderPane>
